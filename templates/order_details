{% extends "base.html" %}
{% block content %}

<h2>Order Details 📦</h2>

<p><strong>Order ID:</strong> {{ order.order_id }}</p>
<p><strong>Status:</strong> {{ order.status }}</p>

<table border="1" width="60%">
<tr>
    <th>Item</th>
    <th>Qty</th>
    <th>Price</th>
</tr>

{% for item in items %}
<tr>
    <td>{{ item.name }}</td>
    <td>{{ item.quantity }}</td>
    <td>₹ {{ item.price }}</td>
</tr>
{% endfor %}

</table>

{% endblock %}
